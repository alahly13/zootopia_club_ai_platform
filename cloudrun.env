# cloudrun.env
#
# Canonical local Cloud Run runtime env file. Use this file with:
#   gcloud run deploy ... --env-vars-file=cloudrun.env
#   gcloud run services update ... --env-vars-file=cloudrun.env
#
# Temporary security-sensitive workflow:
# - `serviceAccountKey.json` is intentionally bundled into `/app/serviceAccountKey.json`
# - `GOOGLE_APPLICATION_CREDENTIALS` points to that container path explicitly
# - replace this with Secret Manager or attached Cloud Run credentials later

# Runtime
NODE_ENV=production
DISABLE_HMR=false
DEPLOY_TARGET=cloud_run
# Primary auth sessions and document-runtime state now persist in Firestore.
# No Redis variable is required for the current runtime path.
GOOGLE_APPLICATION_CREDENTIALS=/app/serviceAccountKey.json
DOCUMENT_EXTRACTION_ENGINE=datalab_convert
DOCUMENT_RUNTIME_PYTHON_EXECUTABLE=/app/.venv/bin/python
# Backend-only extraction settings. Keep `DATALAB_API_KEY` in Secret Manager or
# another secure Cloud Run secret path instead of committing it here.
DATALAB_API_KEY=S_ffWG6UaXBekvbr9pZegmGVquiA6XUKyOgtwXODRNo
DATALAB_BASE_URL=https://www.datalab.to
DATALAB_CONVERT_MODE=balanced
DATALAB_CONVERT_OUTPUT_FORMAT=markdown
DATALAB_CONVERT_PAGINATE=true
DATALAB_DISABLE_IMAGE_CAPTIONS=true
DATALAB_DISABLE_IMAGE_EXTRACTION=false
DATALAB_SAVE_CHECKPOINT=true
DATALAB_SKIP_CACHE=false
DATALAB_CONVERT_POLL_INTERVAL_MS=1500
DATALAB_CONVERT_POLL_TIMEOUT_MS=240000

# AI Providers
GEMINI_API_KEY=AIzaSyCK03H_ewSJosNAPVowbE_QmgeyL9rdF74
DASHSCOPE_API_KEY=sk-352c675eb1e84a9dbeebd1ac9ba8daae
# Official Alibaba Cloud Model Studio server-side configuration.
# This project is currently wired for a US (Virginia) DashScope API key and
# must use the matching compatible-mode endpoint.
ALIBABA_MODEL_STUDIO_REGION=us-virginia
ALIBABA_MODEL_STUDIO_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
# Optional and only required for the Frankfurt region.
ALIBABA_MODEL_STUDIO_WORKSPACE_ID=ws-xqr9rihhdyfwdsg7

# Legacy aliases are still accepted for backward compatibility only.
QWEN_API_KEY=
QWEN_REGION=
QWEN_BASE_URL=

