# .env.example

# Runtime
NODE_ENV=development
DISABLE_HMR=false
# Hosting platforms inject PORT dynamically in production. Keep the local
# fallback for development, but preserve this variable in deployment envs.
PORT=3000
# Optional runtime target hint:
# - local
# - firebase_hosting
# - netlify
# - cloud_run
DEPLOY_TARGET=local

# Frontend runtime hints
# Leave VITE_API_BASE_URL blank for:
# - local integrated development (`npm run dev`)
# - Firebase Hosting rewrites (`/api/**` -> Cloud Run)
# Set VITE_API_BASE_URL only when the frontend is hosted separately
# (for example Netlify -> Cloud Run backend).
VITE_DEPLOY_TARGET=local
VITE_PUBLIC_APP_URL=http://localhost:3000
VITE_API_BASE_URL=
# Optional local override. Leave blank to auto-relax timeouts for local dev.
# Supported values: standard, relaxed
VITE_RUNTIME_TIMEOUT_PROFILE=

# Document runtime / deployment
REDIS_URL=
AUTH_SESSION_REDIS_KEY_PREFIX=zootopia:auth
AUTH_SESSION_MAX_LIFETIME_SEC=10800
# Legacy per-mode TTL variables remain for compatibility, but the auth-session
# runtime now clamps every lane to this hard 3-hour maximum lifetime.
AUTH_SESSION_NORMAL_TTL_SEC=10800
AUTH_SESSION_FAST_ACCESS_TTL_SEC=10800
AUTH_SESSION_ADMIN_TTL_SEC=10800
AUTH_SESSION_INVALIDATION_TTL_SEC=86400
AUTH_SESSION_MEMORY_FALLBACK_ENABLED=true
# The runtime will auto-detect a repo-local `.venv` created by the deployment
# helpers. Override this only when the Python worker lives elsewhere.
DOCUMENT_RUNTIME_PYTHON_EXECUTABLE=python
DOCUMENT_RUNTIME_PYTHON_EXTRACTION_ENABLED=true
DOCUMENT_RUNTIME_PYTHON_SCRIPT_PATH=server/documentRuntime/python/extract_document.py

# AI Providers
GEMINI_API_KEY=your-gemini-api-key
DASHSCOPE_API_KEY=your-dashscope-api-key
# Official Alibaba Cloud Model Studio server-side configuration.
# This project is currently wired for a US (Virginia) DashScope API key and
# must use the matching compatible-mode endpoint.
ALIBABA_MODEL_STUDIO_REGION=us-virginia
ALIBABA_MODEL_STUDIO_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
# Optional and only required for the Frankfurt region.
ALIBABA_MODEL_STUDIO_WORKSPACE_ID=ws-xqr9rihhdyfwdsg7

# Legacy aliases are still accepted for backward compatibility only.
QWEN_API_KEY=
QWEN_REGION=
QWEN_BASE_URL=

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-app-password
EMAIL_FROM=Zootopia Club <your-email@example.com>
ADMIN_EMAIL=admin@example.com

# Payment Provider Configuration (Paymob)
PAYMOB_API_KEY=
PAYMOB_IFRAME_ID=
PAYMOB_INTEGRATION_ID=
PAYMOB_HMAC_SECRET=

# Future Payment Providers (Placeholders)
FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=
EASYKASH_API_KEY=
EASYKASH_MERCHANT_ID=
EASYKASH_WEBHOOK_SECRET=

# Application URL (for redirects and webhooks)
# Keep APP_URL on the public frontend origin that users return to:
# - local dev: http://localhost:3000/
# - Firebase Hosting example: https://zootopia2026.web.app/
# - Netlify example: https://venerable-melomakarona-8f52fc.netlify.app/
APP_URL=http://localhost:3000/
# Comma-separated browser origins allowed to call the backend directly.
# Leave local defaults in development. In Cloud Run, include every frontend
# origin that should call the API cross-origin (for example Netlify plus
# Firebase Hosting if both are active).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
