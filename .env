ALIBABA_MODEL_STUDIO_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
# Optional and only required for the Frankfurt region.
ALIBABA_MODEL_STUDIO_WORKSPACE_ID=ws-xqr9rihhdyfwdsg7

# Legacy aliases are still accepted for backward compatibility only.
QWEN_API_KEY=
QWEN_REGION=
QWEN_BASE_URL=

